generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  name             String?
  passwordHash     String?
  gender              String?
  birthdate           DateTime? @db.Date
  educationalLevel    String?
  educationalStatus   String?
  isAdmin             Boolean  @default(false)

  testRiasec1 Json?
  testRiasec2 Json?
  testRiasec3 Json?
  testRiasec4 Json?

  testHexaco1 Json?
  testHexaco2 Json?
  testHexaco3 Json?

  activeTestId        String?
  activeTestStartedAt DateTime?

  testReadingComprehension  Json?
  testDeductiveReasoning    Json?
  testInductiveReasoning    Json?
  testMathematicalReasoning Json?
  testSpatialReasoning      Json?
  testSelectiveAttention    Json?

  profile Json?   // [R,I,A,S,E,C, H,E,X,A,C,O, RC,DR,IR,MR,SR,SA] — null por dimensión si test incompleto

  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String @unique
  expires    DateTime

  @@id([identifier, token])
}

// --- Application: careers (denormalized with precomputed scores) ---

model Career {
  onetsocCode           String  @id @map("onetsoc_code") @db.Char(10)
  academicLevel         String  @map("academic_level") @db.Char(2)
  title                 String  @db.VarChar(150)
  description           String  @db.VarChar(1500)

  interestsR            Decimal @map("interests_R") @db.Decimal(6, 3)
  interestsI            Decimal @map("interests_I") @db.Decimal(6, 3)
  interestsA            Decimal @map("interests_A") @db.Decimal(6, 3)
  interestsS            Decimal @map("interests_S") @db.Decimal(6, 3)
  interestsE            Decimal @map("interests_E") @db.Decimal(6, 3)
  interestsC            Decimal @map("interests_C") @db.Decimal(6, 3)

  personalityH          Decimal @map("personality_H") @db.Decimal(6, 3)
  personalityE          Decimal @map("personality_E") @db.Decimal(6, 3)
  personalityX          Decimal @map("personality_X") @db.Decimal(6, 3)
  personalityA          Decimal @map("personality_A") @db.Decimal(6, 3)
  personalityC          Decimal @map("personality_C") @db.Decimal(6, 3)
  personalityO          Decimal @map("personality_O") @db.Decimal(6, 3)

  readingComprehension  Decimal @map("reading_comprehension") @db.Decimal(6, 3)
  deductiveReasoning    Decimal @map("deductive_reasoning") @db.Decimal(6, 3)
  inductiveReasoning    Decimal @map("inductive_reasoning") @db.Decimal(6, 3)
  mathematicalReasoning Decimal @map("mathematical_reasoning") @db.Decimal(6, 3)
  spatialReasoning      Decimal @map("spatial_reasoning") @db.Decimal(6, 3)
  selectiveAttention    Decimal @map("selective_attention") @db.Decimal(6, 3)

  @@map("careers")
}

// --- O*NET reference tables ---

model OccupationData {
  onetsocCode String @id @map("onetsoc_code") @db.Char(10)
  title       String @db.VarChar(150)
  description String @db.VarChar(1500)

  @@map("occupation_data")
}

model OccupationDataFilteredAndTranslated {
  onetsocCode   String @map("onetsoc_code") @db.Char(10)
  academicLevel String @map("academic_level") @db.Char(2)
  title         String @db.VarChar(150)
  description   String @db.VarChar(1500)

  @@id([onetsocCode, academicLevel])
  @@map("occupation_data_filtered_and_translated")
}

model ContentModelReference {
  elementId   String @id @map("element_id") @db.VarChar(20)
  elementName String @map("element_name") @db.VarChar(150)
  description String @db.VarChar(1500)

  interests  OnetInterest[]
  workStyles WorkStyle[]
  abilities  Ability[]

  @@map("content_model_reference")
}

model ScalesReference {
  scaleId   String @id @map("scale_id") @db.VarChar(3)
  scaleName String @map("scale_name") @db.VarChar(50)
  minimum   Int
  maximum   Int

  interests  OnetInterest[]
  workStyles WorkStyle[]
  abilities  Ability[]

  @@map("scales_reference")
}

model OnetInterest {
  id           Int      @id @default(autoincrement())
  onetsocCode  String   @map("onetsoc_code") @db.Char(10)
  elementId    String   @map("element_id") @db.VarChar(20)
  scaleId      String   @map("scale_id") @db.VarChar(3)
  dataValue    Decimal  @map("data_value") @db.Decimal(5, 2)
  dateUpdated  DateTime @map("date_updated") @db.Date
  domainSource String   @map("domain_source") @db.VarChar(30)

  contentModelReference ContentModelReference @relation(fields: [elementId], references: [elementId], onDelete: Cascade)
  scalesReference       ScalesReference       @relation(fields: [scaleId], references: [scaleId], onDelete: Cascade)

  @@map("onet_interests")
}

model WorkStyle {
  id           Int      @id @default(autoincrement())
  onetsocCode  String   @map("onetsoc_code") @db.Char(10)
  elementId    String   @map("element_id") @db.VarChar(20)
  scaleId      String   @map("scale_id") @db.VarChar(3)
  dataValue    Decimal  @map("data_value") @db.Decimal(5, 2)
  dateUpdated  DateTime @map("date_updated") @db.Date
  domainSource String   @map("domain_source") @db.VarChar(30)

  contentModelReference ContentModelReference @relation(fields: [elementId], references: [elementId], onDelete: Cascade)
  scalesReference       ScalesReference       @relation(fields: [scaleId], references: [scaleId], onDelete: Cascade)

  @@map("work_styles")
}

model Ability {
  onetsocCode       String   @map("onetsoc_code") @db.Char(10)
  elementId         String   @map("element_id") @db.VarChar(20)
  scaleId           String   @map("scale_id") @db.VarChar(3)
  dataValue         Decimal  @map("data_value") @db.Decimal(5, 2)
  n                 Decimal? @db.Decimal(4, 0)
  standardError     Decimal? @map("standard_error") @db.Decimal(7, 4)
  lowerCiBound      Decimal? @map("lower_ci_bound") @db.Decimal(7, 4)
  upperCiBound      Decimal? @map("upper_ci_bound") @db.Decimal(7, 4)
  recommendSuppress String?  @map("recommend_suppress") @db.Char(1)
  notRelevant       String?  @map("not_relevant") @db.Char(1)
  dateUpdated       DateTime @map("date_updated") @db.Date
  domainSource      String   @map("domain_source") @db.VarChar(30)

  contentModelReference ContentModelReference @relation(fields: [elementId], references: [elementId], onDelete: Cascade)
  scalesReference       ScalesReference       @relation(fields: [scaleId], references: [scaleId], onDelete: Cascade)

  @@id([onetsocCode, elementId, scaleId])
  @@map("abilities")
}

model SniesProgram {
  codigoprograma               String   @id
  codigoinstitucion            Int?
  nombreinstitucion            String?
  codigodepartinstitucion      Int?
  nombredepartinstitucion      String?
  codigomunicipioinstitucion   Int?
  nombremunicipioinstitucion   String?
  codigoorigeninstitucional    Int?
  nombreorigeninstitucional    String?
  codigocaracteracademico      Int?
  nombrecaracteracademico      String?
  nombreprograma               String?
  codigodepartprograma         String?
  nombredepartprograma         String?
  codigomunicipioprograma      String?
  nombremunicipioprograma      String?
  codigoestadoprograma         Int?
  nombreestadoprograma         String?
  cantidadcreditos             String?
  fechaacreditacion            String?
  codigoareaconocimiento       String?
  nombreareaconocimiento       String?
  codigometodologia            Int?
  nombremetodologia            String?
  codigonbc                    String?
  nombrenbc                    String?
  codigonivelformacion         Int?
  nombrenivelformacion         String?
  codigonivelacademico         Int?
  nombrenivelacademico         String?
  codigoperiodicidad           Int?
  nombreperiodicidad           String?
  cantidadperiodos             String?
  numeroresolucionacreditacion String?
  codigotipoacreditacion       Int?
  nombretipoacreditacion       String?
  aniosacreditados             String?
  nombretituloobtenido         String?
  fechacreacion                String?
  fetchedAt                    DateTime @default(now())

  @@index([nombreprograma])
  @@index([codigomunicipioprograma])
  @@map("snies_programs")
}

model Location {
  codeLocation   String  @id @map("code_location")
  name           String
  codeDepartment String  @map("code_department")
  lat            Float?
  lng            Float?

  @@map("locations")
}
