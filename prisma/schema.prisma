generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  name             String?
  passwordHash     String?
  gender           String?
  birthdate        DateTime? @db.Date
  educationalLevel String?

  testRiasec1 Json?
  testRiasec2 Json?
  testRiasec3 Json?
  testRiasec4 Json?

  testHexaco1 Json?
  testHexaco2 Json?
  testHexaco3 Json?

  activeTestId        String?
  activeTestStartedAt DateTime?

  testReadingComprehension  Json?
  testDeductiveReasoning    Json?
  testInductiveReasoning    Json?
  testMathematicalReasoning Json?
  testMemorization          Json?
  testPerceptualSpeed       Json?
  testSpatialReasoning      Json?
  testSelectiveAttention    Json?

  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String @unique
  expires    DateTime

  @@id([identifier, token])
}

// --- O*NET reference tables ---

model Career {
  onetsocCode String @id @map("onetsoc_code") @db.Char(10)
  level       String @db.Char(2)
  title       String @db.VarChar(150)
  description String @db.VarChar(1500)

  interests  OnetInterest[]
  workStyles WorkStyle[]

  @@map("careers")
}

model ContentModelReference {
  elementId   String @id @map("element_id") @db.VarChar(20)
  elementName String @map("element_name") @db.VarChar(150)
  description String @db.VarChar(1500)

  interests  OnetInterest[]
  workStyles WorkStyle[]

  @@map("content_model_reference")
}

model ScalesReference {
  scaleId   String @id @map("scale_id") @db.VarChar(3)
  scaleName String @map("scale_name") @db.VarChar(50)
  minimum   Int
  maximum   Int

  interests  OnetInterest[]
  workStyles WorkStyle[]

  @@map("scales_reference")
}

model OnetInterest {
  id          Int      @id @default(autoincrement())
  onetsocCode String   @map("onetsoc_code") @db.Char(10)
  elementId   String   @map("element_id") @db.VarChar(20)
  scaleId     String   @map("scale_id") @db.VarChar(3)
  dataValue   Decimal  @map("data_value") @db.Decimal(5, 2)
  dateUpdated DateTime @map("date_updated") @db.Date
  domainSource String  @map("domain_source") @db.VarChar(30)

  career                Career                @relation(fields: [onetsocCode], references: [onetsocCode], onDelete: Cascade)
  contentModelReference ContentModelReference @relation(fields: [elementId], references: [elementId], onDelete: Cascade)
  scalesReference       ScalesReference       @relation(fields: [scaleId], references: [scaleId], onDelete: Cascade)

  @@map("onet_interests")
}

model WorkStyle {
  id          Int      @id @default(autoincrement())
  onetsocCode String   @map("onetsoc_code") @db.Char(10)
  elementId   String   @map("element_id") @db.VarChar(20)
  scaleId     String   @map("scale_id") @db.VarChar(3)
  dataValue   Decimal  @map("data_value") @db.Decimal(5, 2)
  dateUpdated DateTime @map("date_updated") @db.Date
  domainSource String  @map("domain_source") @db.VarChar(30)

  career                Career                @relation(fields: [onetsocCode], references: [onetsocCode], onDelete: Cascade)
  contentModelReference ContentModelReference @relation(fields: [elementId], references: [elementId], onDelete: Cascade)
  scalesReference       ScalesReference       @relation(fields: [scaleId], references: [scaleId], onDelete: Cascade)

  @@map("work_styles")
}
