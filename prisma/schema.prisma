generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  name             String?
  passwordHash     String?
  gender           String?
  birthdate        DateTime? @db.Date
  educationalLevel String?

  // RIASEC test results (4 attempts)
  testRiasec1 Json?
  testRiasec2 Json?
  testRiasec3 Json?
  testRiasec4 Json?

  // HEXACO test results (3 attempts)
  testHexaco1 Json?
  testHexaco2 Json?
  testHexaco3 Json?

  // Active skill test session (for secure timer)
  activeTestId        String?
  activeTestStartedAt DateTime?

  // Skill test results (8 tests)
  testReadingComprehension  Json?
  testDeductiveReasoning    Json?
  testInductiveReasoning    Json?
  testMathematicalReasoning Json?
  testMemorization          Json?
  testPerceptualSpeed       Json?
  testSpatialReasoning      Json?
  testSelectiveAttention    Json?

  // NextAuth fields
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String @unique
  expires    DateTime

  @@id([identifier, token])
}
